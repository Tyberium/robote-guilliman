# GCP
GCP_PROJECT_ID=roboto-guilliman
GCP_LOCATION=us-central1

# Firestore
FIRESTORE_COLLECTION=warhammer_rules_11th
FIRESTORE_DATABASE=(default)
CHAT_HISTORY_COLLECTION=chat_history

# Models
EMBEDDING_MODEL=text-embedding-004
LLM_MODEL=gemini-2.5-flash-lite

# RAG (smaller chunks = fewer tokens per query on free tier)
TOP_K=6
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# API
PORT=8080
LOG_LEVEL=INFO
